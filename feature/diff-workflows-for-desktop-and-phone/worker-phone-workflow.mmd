%% Worker phone workflow — Brick Counter Coordinator
%%
%% Persona: counter at the table on phone (< md viewport or worker profile)
%% Shared phase machine: docs/session-phases-state.mmd (same session phases; narrower screens)
%% Feature: diff-workflows-for-desktop-and-phone (#90)
%%
%% Workers do NOT run import, reconcile, or export. Coordinator advances those phases.

flowchart TB
    subgraph discover["Discovery — Marketing shell"]
        EnterName["Enter display name\n(storyboard join identity)"]
        HomeList["Home — session list\n2–3 fixture sessions"]
    end

    subgraph count["Counting — Worker shell (< md viewport)"]
        LotEntry["Lot entry — counting cockpit"]
        LotsBrowse["List lots — browse recorded lots"]
        Cups["List cups — physical containers"]
    end

    subgraph organize["Organizing — Worker shell (assigned list)"]
        Prompt{{"Dismissible toast:\nGo to my put-away list"}}
        MyList["My assigned pick list\n≥50 lines: lazy scroll\nMark moved / needs location"]
    end

    WaitImport["Not joinable yet\nSession still in import / setup"]
    WaitReconcile["Counting paused\nCoordinator reconciling — check back"]
    Done["Session complete\nReturn to session list"]

    EnterName --> HomeList
    HomeList -->|"Select session"| RoutePhase{Session phase?}

    RoutePhase -->|importing| WaitImport
    RoutePhase -->|counting| LotEntry
    LotEntry <-->|"Nav"| LotsBrowse
    LotEntry <-->|"Nav"| Cups
    RoutePhase -->|reconciling| WaitReconcile
    RoutePhase -->|organizing| MyList
    RoutePhase -->|updating_inventory / closed| Done

    WaitImport -.-> HomeList
    WaitReconcile -.-> HomeList

    LotEntry -->|"Coordinator starts organize\n(WebSocket / storyboard push)"| Prompt
    Prompt -->|"Accept"| MyList
    Prompt -.->|"Dismiss — stay counting\nuntil phase requires organize"| LotEntry

    MyList -.->|"Optional: back to counting\nwhen phase allows"| LotEntry
    MyList -->|"Coordinator completes session"| Done
    Done --> HomeList

    note1["Reduced nav: Home, Lot, Lots, Cups\nNo Reconcile, Import, Export, or all-list organizer"]
    note1 -.-> count

    note2["One assigned list per worker — not all coordinator lists"]
    note2 -.-> MyList
